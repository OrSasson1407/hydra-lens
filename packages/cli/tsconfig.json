{
    "extends":  "../../tsconfig.json",
    "compilerOptions":  {
                            "composite":  true,
                            "target":  "ES2020",
                            "module":  "CommonJS",
                            "moduleResolution":  "node",
                            "outDir":  "./dist",
                            "rootDir":  "./src",
                            "declaration":  true,
                            "sourceMap":  true,
                            "lib":  [
                                        "ES2020",
                                        "DOM"
                                    ]
                        },
    "include":  [
                    "src/**/*"
                ],
    "exclude":  [
                    "node_modules",
                    "dist",
                    "**/*.test.ts",
                    "**/*.spec.ts"
                ],
    "references":  [
                       {
                           "path":  "../core"
                       }
                   ]
}
