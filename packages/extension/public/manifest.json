{
    "manifest_version":  3,
    "name":  "HydraLens - Hydration Debugger",
    "version":  "0.6.0",
    "description":  "Debug React, Vue, Angular, Next.js, Nuxt, Svelte and SolidJS hydration mismatches in real-time with fix advice, security scanning, export reports, and CI/CD integration.",
    "icons":  {
                  "16":  "icon16.png",
                  "48":  "icon48.png",
                  "128":  "icon128.png"
              },
    "devtools_page":  "src/devtools/devtools.html",
    "action":  {
                   "default_title":  "HydraLens",
                   "default_popup":  "popup/popup.html"
               },
    "background":  {
                       "service_worker":  "background.js",
                       "type":  "module"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle"
                            }
                        ],
    "permissions":  [
                        "activeTab",
                        "scripting",
                        "tabs",
                        "storage",
                        "webNavigation"
                    ],
    "commands":  {
                     "trigger-scan":  {
                                          "suggested_key":  {
                                                                "default":  "Alt+Shift+H",
                                                                "mac":  "Alt+Shift+H"
                                                            },
                                          "description":  "Trigger a HydraLens scan on the current tab"
                                      }
                 }
}