{
  "manifest_version": 3,
  "name": "HydraLens",
  "version": "0.1.0",
  "description": "Visualizes React hydration mismatches directly in the DOM.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Toggle HydraLens"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"] 
    }
  ]
}