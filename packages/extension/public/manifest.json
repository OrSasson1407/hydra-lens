{
  "manifest_version": 3,
  "name": "HydraLens",
  "version": "0.1.0",
  "description": "Visualizes React hydration mismatches directly in the DOM.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "action": {
    "default_title": "Open HydraLens",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
