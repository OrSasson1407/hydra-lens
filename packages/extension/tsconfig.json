{
    "compilerOptions":  {
                            "composite":  true,
                            "target":  "ESNext",
                            "module":  "ESNext",
                            "moduleResolution":  "bundler",
                            "declaration":  true,
                            "declarationMap":  true,
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "lib":  [
                                        "DOM",
                                        "DOM.Iterable",
                                        "ESNext"
                                    ],
                            "types":  [
                                          "chrome"
                                      ],
                            "noEmit":  false,
                            "outDir":  "./dist",
                            "rootDir":  "./src"
                        },
    "include":  [
                    "src/**/*"
                ],
    "exclude":  [
                    "node_modules",
                    "dist",
                    "src/**/*.test.ts",
                    "src/**/*.spec.ts",
                    "src/**/__tests__/**",
                    "src/test-setup.ts"
                ],
    "references":  [
                       {
                           "path":  "../core"
                       }
                   ]
}
