{
  "name": "hydra-lens-monorepo",
  "private": true,
 "scripts": {
    "build:extension": "pnpm --filter hydra-lens-extension build",
    "build:core": "pnpm --filter @hydra-lens/core build",
    "build": "pnpm build:core && pnpm build:extension",
    "test": "pnpm run test:unit && pnpm run test:integration",
    
    "test:unit": "vitest run .unit.test.ts",
    "test:integration": "vitest run .integration.test.ts",
    "test:fuzz": "vitest run .fuzz.test.ts",
    "test:security": "vitest run .sec.test.ts",
    "test:bench": "vitest bench --run",
    
    "test:e2e:cli": "playwright test packages/cli/tests/e2e",
    "test:e2e:extension": "playwright test packages/extension/tests/e2e",
    "test:e2e:xss": "playwright test packages/extension/tests/security",
    "test:system": "playwright test tests/system",
    "test:mutate": "stryker run",
    
    "test:all": "pnpm run test:unit && pnpm run test:integration && pnpm run test:security && pnpm run test:e2e:cli && pnpm run test:e2e:extension && pnpm run test:system",
    "test:insane": "pnpm run test:all && pnpm run test:fuzz && pnpm run test:bench && pnpm run test:mutate"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^8.0.0",
    "@stryker-mutator/vitest-runner": "^8.0.0",
    "@vitest/ui": "^4.1.8",
    "fast-check": "^3.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}