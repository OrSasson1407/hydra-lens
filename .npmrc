# npm registry for publishing @hydra-lens/core
registry=https://registry.npmjs.org/

# Use the NPM_TOKEN secret injected by CI
# Token is only needed for publishing ? CI sets NPM_TOKEN, local builds skip this
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}

strict-peer-dependencies=false
auto-install-peers=true

# NOTE: pnpm supply-chain policies (minimumReleaseAge) belong in
# pnpm-workspace.yaml under the `pnpm:` key, NOT here.
