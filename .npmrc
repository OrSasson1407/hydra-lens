# npm registry for publishing @hydra-lens/core
registry=https://registry.npmjs.org/

# Use the NPM_TOKEN secret injected by CI (GitHub Actions / release.yml)
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Never publish packages marked "private: true" accidentally
# (packages/cli and packages/extension are private; only @hydra-lens/core publishes)
strict-peer-dependencies=false
auto-install-peers=true

minimum-release-age=0
